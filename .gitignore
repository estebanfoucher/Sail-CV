# ===========================================
# Sail-CV .gitignore
# ===========================================

# Model files and checkpoints (large binary files)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5
*.pkl
*.pickle
*.joblib
weights/

plots*/

# Allow specific checkpoint files
!checkpoints/
!checkpoints/rt-detr.pt
!checkpoints/yolo-s.pt

!README.md

# Data directories (input data, not tracked)
data/
datasets/
raw_data/
assets-3d/
assets-3d/**
publication/
publication/**
# Output directories (generated content)
output/
output_tests/
results/
logs/
temp/

# Python cache and compiled files
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# MyPy cache
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff cache
.ruff_cache/

# Pre-commit cache
.pre-commit-cache/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Large media files (except in assets/)
*.mp4
!assets/**/*.mp4
*.avi
*.mov
!assets/**/*.MOV
!assets/**/*.mov
*.mkv
*.wmv
*.flv
*.webm
*.m4v
*.3gp
*.jpg
*.jpeg
*.png
!assets/**/*.png
*.bmp
*.tiff
*.tif
*.svg
*.webp
*.heic
*.heif
*.raw
*.cr2
*.nef
*.arw
*.dng

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.bz2
*.xz

# Database files
*.db
*.sqlite
*.sqlite3

# Log files
*.log
*.out
*.err

# Docker volumes and data
docker/data/
docker/volumes/

# Environment-specific files
.env
.env.local
.env.development
.env.production
.env.test

# Backup files
*.bak
*.backup
*.old
*.orig

# Temporary files
*.tmp
*.temp
.cache/
