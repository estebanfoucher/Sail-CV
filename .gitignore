# Restrictive approach: ignore everything by default, then explicitly allow
*
!.gitignore
!README.md
!DEVELOPMENT.md
!.env

# Source code
!src/
!src/**

# Tests
!tests/
!tests/**

# Docker configuration
!docker/
!docker/**
!docker/.env

# Project configuration
!pyproject.toml
!uv.lock
!requirements-dev.txt
!Makefile

# Development scripts
!scripts/
!scripts/**

# Documentation and project files
!TODO.txt
!launch.sh
!config.json

# External dependencies (MASt3R)
!mast3r/
!mast3r/**
# !pow3r/
# !pow3r/**

# Assets directory (for scene images)
!assets/
!assets/**


!web_app/
!web_app/**

# Pre-commit configuration
!.pre-commit-config.yaml

# ===========================================
# EXCLUSIONS - Files/directories to ignore
# ===========================================

# Model files and checkpoints (large binary files)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5
*.pkl
*.pickle
*.joblib
checkpoints/
models/
weights/

# Data directories (input data, not tracked)
data/
datasets/
raw_data/

# Output directories (generated content)
output/
results/
logs/
temp/

# Python cache and compiled files
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# MyPy cache
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff cache
.ruff_cache/

# Pre-commit cache
.pre-commit-cache/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Large media files (images, videos, audio)
*.mp4 # except those in assets/
!assets/**/*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm
*.m4v
*.3gp
*.jpg
*.jpeg
*.png

!assets/**/*.png
*.bmp
*.tiff
*.tif
*.svg
*.webp
*.heic
*.heif
*.raw
*.cr2
*.nef
*.arw
*.dng

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.bz2
*.xz

# Database files
*.db
*.sqlite
*.sqlite3

# Log files
*.log
*.out
*.err

# Specific exclusions for test assets
src/cameras/test_assets/camera_pyramids/**

# Docker volumes and data
docker/data/
docker/volumes/

# Environment-specific files
.env.local
.env.development
.env.production
.env.test

# Backup files
*.bak
*.backup
*.old
*.orig

# Temporary files
*.tmp
*.temp
.cache/
*.DS_Store
